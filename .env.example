NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Necessária para o cron de sincronização do Google Drive (acesso server-only ao banco).
# Pegue em Supabase → Project Settings → API → service_role (SECRETA, nunca exponha no navegador).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Conta de serviço do Google Drive (sincronização Drive → Lote).
# Gere em console.cloud.google.com → conta de serviço → chave JSON.
GOOGLE_DRIVE_CLIENT_EMAIL=painel-ro-drive@xxxxx.iam.gserviceaccount.com
# Cole o valor do campo "private_key" do JSON, com as aspas e os \n literais.
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Opcional: pasta-raiz do Drive (não obrigatório com vínculo por lote).
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Protege a rota do cron. Defina o MESMO valor na Vercel (Settings → Environment Variables).
# A Vercel envia este segredo automaticamente como Bearer ao disparar o cron.
CRON_SECRET=uma-senha-aleatoria-longa
